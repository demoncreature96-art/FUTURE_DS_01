      <aliases enabled='yes' />
      <column caption='Important Labels' datatype='string' name='[Calculation_1168574397992960]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) = WINDOW_MAX(SUM([Profit]))&#13;&#10;THEN &quot;Highest Profit&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([Profit]) = WINDOW_MIN(SUM([Profit]))&#13;&#10;THEN &quot;Biggest Loss&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([Sales]) = WINDOW_MAX(SUM([Sales]))&#13;&#10;THEN &quot;Highest Sales&quot;&#13;&#10;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Profit margin%' datatype='real' name='[Calculation_1306220599717892]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_1306220629438469]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Order ID])' />
      </column>
